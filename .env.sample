MYSQL_ROOT_PASSWORD=docker
MYSQL_USER=docker
MYSQL_PASSWORD=docker
MYSQL_HOST=db
MYSQL_DATABASE=hadithdb

FLASK_ENV=development
FLASK_APP=main.py

AWS_SECRET=secret

ELASTIC_PASSWORD=123
ES_PORT=9200
ES_STACK_VERSION=8.16.0

INDEXING_PASSWORD=index123

# Query-time embedding runs on a local Infinity server (michaelf34/infinity).
# On Linux set INFINITY_URL explicitly — see README.
# INFINITY_URL=http://host.docker.internal:7997
SEMANTIC_ENABLED=true
# Log every query router decision (route, variant, whether mode was overridden).
# Enable before going live to audit real-world routing. Off by default.
# ROUTER_LOG=true
# Index-time embedding via your own HF Dedicated Inference Endpoint (TEI-backed).
# Query-time embedding always stays on the local Infinity server. Unset either
# var → ES embeds via Infinity at index time too (slower; fine for local dev).
HUGGING_FACE_KEY=key
# HF Inference Endpoint base URL (no trailing slash, no /v1/embeddings — we append).
HF_DEDICATED_URL=https://some-endpoint
# Resume cache: persists embedded batches to disk so a build interrupted by an
# endpoint hiccup resumes instead of re-embedding the whole corpus. Deleted on
# success. Set to false to disable (e.g. read-only filesystem).
# EMBED_CHECKPOINT_ENABLED=true

# Grafana Cloud — logs (Loki)
# Get from: grafana.com → your stack → Loki card → "Send Logs"
# Token: My Account → Access Policies → token with logs:write scope
GC_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GC_LOKI_USER=123456
GC_LOKI_PASSWORD=glc_xxxxxxxxxxxx

# Grafana Cloud — metrics (Prometheus / Mimir)
# Get from: grafana.com → your stack → Prometheus card → "Send Metrics"
# Token: same Access Policies page; can reuse the Loki token if its policy
# also grants metrics:write, otherwise create a separate one.
GC_PROM_URL=https://prometheus-prod-XX-prod-us-east-0.grafana.net/api/prom/push
GC_PROM_USER=789012
GC_PROM_PASSWORD=glc_xxxxxxxxxxxx

# Optional — overrides the default ("local" for docker-compose.yml, "prod"
# for docker-compose.prod.yml). Used as the `env` label on shipped telemetry.
# DEPLOY_ENV=staging

# searchdb — separate MySQL holding the `search_metrics` shadow-sampling table.
# These defaults match the `searchdb` service in docker-compose.yml; override
# with the real credentials in prod.
searchdb_host=searchdb
searchdb_name=searchdb
searchdb_username=docker
searchdb_password=docker

# Shadow sampling: percent (0–100) of lexical-served queries to ALSO run through
# semantic in the background, storing both results + timings in search_metrics.
# 0 or unset = disabled (the feature stays dark). Requires SEMANTIC_ENABLED=true
# and a reachable searchdb. Optional: SEARCH_METRICS_WORKERS (default 2),
# SEARCH_METRICS_MAX_INFLIGHT (default 50, backlog cap before samples are dropped).
SEARCH_METRICS_SAMPLE_PERCENT=0